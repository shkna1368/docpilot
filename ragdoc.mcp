                "content": "import httpx\nfrom bs4 import BeautifulSoup\nfrom ..scraper import BaseScraper, DocPage\n\nBASE_URL = \"https://docs.spring.io/spring-data/commons/reference\"\nPATHS = [\n    \"/repositories/definition.html\", \"/repositories/query-methods.html\",\n    \"/repositories/custom-implementations.html\",\n    \"/query-by-example.html\", \"/auditing.html\",\n    \"/projections.html\",\n]\n\nJPA_BASE = \"https://docs.spring.io/spring-data/jpa/reference\"\nJPA_PATHS = [\n    \"/jpa.repositories.html\", \"/jpa.query-methods.html\",\n    \"/jpa.entity-persistence.html\", \"/specifications.html\",\n]\n\n\nclass SpringDataScraper(BaseScraper):\n    def scrape(self) -> list[DocPage]:\n        pages = []\n        client = httpx.Client(timeout=30, follow_redirects=True)\n        for base, paths, sub in [(BASE_URL, PATHS, \"commons\"), (JPA_BASE, JPA_PATHS, \"jpa\")]:\n            for path in paths:\n                url = base + path\n                try:\n                    resp = client.get(url)\n                    if resp.status_code != 200:\n                        continue\n                    soup = BeautifulSoup(resp.text, \"html.parser\")\n                    article = soup.select_one(\"#content\") or soup.select_one(\"article\") or soup.body\n                    if not article:\n                        continue\n                    title = soup.title.string.strip() if soup.title else path.split(\"/\")[-1].replace(\".html\", \"\")\n                    text = article.get_text(separator=\"\\n\", strip=True)\n                    if len(text) < 100:\n                        continue\n                    section = path.split(\"/\")[-1].replace(\".html\", \"\")\n                    pages.append(DocPage(\n                        url=url, title=title, section_title=section,\n                        text=text, source=\"spring-data\", version=\"2024\",\n                        language=\"java\", topics=\"spring,data,\" + sub + \",\" + section.replace(\"-\", \",\"),\n                        categories=\"java,database,jpa,repository\"\n                    ))\n                except Exception:\n                    continue\n        client.close()\n        return pages\n",
