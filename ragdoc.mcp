        "content": [
          {
            "kind": "text",
            "data": "The issue is that the Quarkus app shuts down before the tool call completes (stdin closes after the messages are sent). The MCP stdio transport reads all messages then exits. I need to keep stdin open a bit longer. Let me add a sleep:"
          },
          {
            "kind": "toolUse",
            "data": {
              "toolUseId": "tooluse_fLZwXnWNfk4WfFB5vZe13O",
              "name": "shell",
              "input": {
                "__tool_use_purpose": "Keep stdin open long enough for the tool to execute",
                "command": "cd /Users/ekoosha/projects/tutorial/mcp-doc && (printf '{\"jsonrpc\":\"2.0\",\"id\":1,\"method\":\"initialize\",\"params\":{\"protocolVersion\":\"2024-11-05\",\"capabilities\":{},\"clientInfo\":{\"name\":\"test\",\"version\":\"1.0\"}}}\\n{\"jsonrpc\":\"2.0\",\"method\":\"notifications/initialized\"}\\n{\"jsonrpc\":\"2.0\",\"id\":2,\"method\":\"tools/call\",\"params\":{\"name\":\"searchDocs\",\"arguments\":{\"query\":\"fiber routing\",\"maxResults\":2}}}\\n'; sleep 15) | docker run -i --rm framework-docs-mcp:latest 2>/dev/null | grep '\"id\":2'"
              }
            }
          }
        ]
      }
    },
